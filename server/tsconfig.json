{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "outDir": "dist",
    "paths": {
      "@orzo/shared": ["../shared/src"],
      "@orzo/shared/*": ["../shared/src/*"]
    }
  },
  "include": ["src", "tests"],
  "exclude": ["tests/machine.test.ts"]
}
