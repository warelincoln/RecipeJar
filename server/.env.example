# Local dev points at the DEV Supabase project (`nrdomcszbvqnfinrjvuz`).
# Production credentials live only in Railway — never put them in this file.
# See docs/SETUP.md "Dev and production are fully isolated" for full context.
#
# Use the Session pooler URL (IPv4). The direct-connect host `db.<ref>.supabase.co`
# is IPv6-only and will fail on most home/office networks (ENOTFOUND).
DATABASE_URL=postgresql://postgres.YOUR_DEV_PROJECT_REF:YOUR_DEV_PASSWORD@aws-0-YOUR_REGION.pooler.supabase.com:5432/postgres
SUPABASE_URL=https://YOUR_DEV_PROJECT_REF.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-dev-service-role-key
OPENAI_API_KEY=your-openai-api-key
PORT=3000

# Sentry observability (optional in dev; required in production).
# Create a project in the Sentry dashboard and paste its DSN here.
# When unset, Sentry.init is a no-op — nothing breaks, we just skip capture.
SENTRY_DSN=
