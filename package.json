{
  "name": "orzo",
  "private": true,
  "overrides": {
    "react-native-svg": "15.15.4"
  },
  "workspaces": [
    "shared",
    "server",
    "mobile"
  ],
  "scripts": {
    "dev:phone": "concurrently -k -n api,metro -c blue,magenta \"npm run dev -w @orzo/server\" \"npm run start -w @orzo/mobile\"",
    "ensure:phone": "bash scripts/ensure-phone-dev.sh",
    "postinstall": "patch-package && node scripts/write-orzo-dev-host.cjs"
  },
  "devDependencies": {
    "concurrently": "^9.1.2",
    "patch-package": "^8.0.1"
  }
}
