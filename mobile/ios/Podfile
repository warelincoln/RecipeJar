require 'fileutils'

# Resolve react_native_pods.rb with node to allow for hoisting
require Pod::Executable.execute_command('node', ['-p',
  'require.resolve(
    "react-native/scripts/react_native_pods.rb",
    {paths: [process.argv[1]]},
  )', __dir__]).strip

platform :ios, min_ios_version_supported
prepare_react_native_project!

# VisionCamera enables CLLocation APIs by default, which causes Apple static analyzer
# to require NSLocationWhenInUseUsageDescription (ITMS-90683) even though Orzo does not
# use location. Disable the location feature since the app does not need it.
$VCEnableLocation = false

linkage = ENV['USE_FRAMEWORKS']
if linkage != nil
  Pod::UI.puts "Configuring Pod with #{linkage}ally linked Frameworks".green
  use_frameworks! :linkage => linkage.to_sym
end

target 'Orzo' do
  config = use_native_modules!

  use_react_native!(
    :path => config[:reactNativePath],
    # An absolute path to your application root.
    :app_path => "#{Pod::Config.instance.installation_root}/.."
  )

  target 'OrzoTests' do
    inherit! :complete
    # Pods for testing
  end

  post_install do |installer|
    # https://github.com/facebook/react-native/blob/main/packages/react-native/scripts/react_native_pods.rb#L197-L202
    react_native_post_install(
      installer,
      config[:reactNativePath],
      :mac_catalyst_enabled => false,
      :ccache_enabled => false
    )

    # Case-insensitive APFS: CocoaPods can leave broken `folly/json` public headers (empty dir,
    # duplicate `json 2`, or `dynamic 2.h`-style renamed files). Recreate symlinks from source.
    folly_json_src = File.join(__dir__, 'Pods', 'RCT-Folly', 'folly', 'json')
    folly_pub = File.join(__dir__, 'Pods', 'Headers', 'Public', 'RCT-Folly', 'folly')
    json_pub = File.join(folly_pub, 'json')
    json_dup = File.join(folly_pub, 'json 2')
    if File.directory?(folly_json_src)
      FileUtils.rm_rf(json_pub)
      FileUtils.rm_rf(json_dup)
      FileUtils.mkdir_p(json_pub)
      Dir.children(folly_json_src).each do |name|
        next if name.start_with?('.')
        src = File.join(folly_json_src, name)
        next unless File.file?(src) || File.symlink?(src)
        dst = File.join(json_pub, name)
        rel = Pathname.new(src).relative_path_from(Pathname.new(json_pub))
        FileUtils.ln_sf(rel.to_s, dst)
      end
      Pod::UI.puts 'Fixed RCT-Folly public headers: rebuilt folly/json symlinks'.green
    end

    # Xcode 26+ Apple Clang claims consteval support but fmt's usage triggers
    # "not a constant expression" errors. Patch base.h to disable consteval.
    fmt_base = File.join(__dir__, 'Pods', 'fmt', 'include', 'fmt', 'base.h')
    if File.exist?(fmt_base)
      File.chmod(0644, fmt_base)
      content = File.read(fmt_base)
      patched = content.sub(
        /^#elif defined\(__cpp_consteval\)\n#  define FMT_USE_CONSTEVAL 1$/,
        "#elif defined(__cpp_consteval)\n#  define FMT_USE_CONSTEVAL 0  // patched: consteval broken on Xcode 26+"
      )
      File.write(fmt_base, patched) if patched != content
    end

    # Paths with spaces break RN's ReactCodegen script: unquoted exports truncate at the first
    # space, and `sh -c "$A $B"` still word-splits when executing the inner command line.
    installer.pods_project.targets.each do |target|
      target.build_phases.each do |phase|
        next unless phase.respond_to?(:shell_script)
        script = phase.shell_script
        next if script.nil? || !script.include?("RCT_SCRIPT_POD_INSTALLATION_ROOT")

        script = script.gsub(
          "export RCT_SCRIPT_RN_DIR=$RCT_SCRIPT_POD_INSTALLATION_ROOT/../../node_modules/react-native",
          'export RCT_SCRIPT_RN_DIR="$RCT_SCRIPT_POD_INSTALLATION_ROOT/../../node_modules/react-native"',
        )
        script = script.gsub(
          "export RCT_SCRIPT_APP_PATH=$RCT_SCRIPT_POD_INSTALLATION_ROOT/..",
          'export RCT_SCRIPT_APP_PATH="$RCT_SCRIPT_POD_INSTALLATION_ROOT/.."',
        )
        script = script.gsub(
          "export RCT_SCRIPT_OUTPUT_DIR=$RCT_SCRIPT_POD_INSTALLATION_ROOT",
          'export RCT_SCRIPT_OUTPUT_DIR="$RCT_SCRIPT_POD_INSTALLATION_ROOT"',
        )
        script = script.gsub(
          '/bin/sh -c "$WITH_ENVIRONMENT $SCRIPT_PHASES_SCRIPT"',
          'bash "$WITH_ENVIRONMENT" "$SCRIPT_PHASES_SCRIPT"',
        )
        script = script.gsub(
          '/bin/sh -c "\"$WITH_ENVIRONMENT\" \"$SCRIPT_PHASES_SCRIPT\""',
          'bash "$WITH_ENVIRONMENT" "$SCRIPT_PHASES_SCRIPT"',
        )
        phase.shell_script = script
      end
    end
    installer.pods_project.save
  end
end
