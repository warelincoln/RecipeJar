{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "jsx": "react-native",
    "paths": {
      "@recipejar/shared": ["../shared/src"],
      "@recipejar/shared/*": ["../shared/src/*"]
    }
  },
  "include": ["src", "App.tsx", "index.js"]
}
